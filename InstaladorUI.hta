<!DOCTYPE html>
<html>
<head>
    <title>Office AutoDeployer Pro</title>
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <meta charset="UTF-8">
    <HTA:APPLICATION 
        ID="OfficeDeployer" 
        APPLICATIONNAME="Office AutoDeployer Pro" 
        ICON="setup.exe"
        SCROLL="auto" 
        SINGLEINSTANCE="yes" 
        WINDOWSTATE="normal"
        INNERBORDER="no"
        CONTEXTMENU="no"
        SELECTION="no"
        BORDER="thin"
    />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #0f111a;
            color: #ffffff;
            margin: 0;
            padding: 0;
            overflow-y: auto;
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        .header {
            display: flex;
            align-items: center;
            padding: 20px 30px;
            background: linear-gradient(90deg, #1a1d29 0%, #0f111a 100%);
            border-bottom: 1px solid #333;
        }
        .logo-text {
            font-size: 24px;
            font-weight: 600;
            margin-left: 15px;
            letter-spacing: 1px;
        }
        .logo-text span {
            color: #d4af37;
        }
        .container {
            flex: 1;
            padding: 20px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }
        .title {
            font-size: 24px;
            margin-bottom: 10px;
            color: #e0e0e0;
            font-weight: 600;
        }
        .subtitle {
            font-size: 15px;
            color: #a0a0a0;
            margin-bottom: 35px;
            text-align: center;
        }
        .card {
            background-color: #161824;
            border: 1px solid #2a2d39;
            border-radius: 16px;
            padding: 35px 40px;
            width: 100%;
            max-width: 650px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.6);
            position: relative;
            overflow: hidden;
        }
        
        /* Efeito de brilho no topo do card estilo Tailwind */
        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, transparent, #d4af37, transparent);
            opacity: 0.8;
        }

        /* Select Version */
        .form-group {
            margin-bottom: 30px;
        }
        label {
            display: block;
            margin-bottom: 12px;
            font-size: 15px;
            color: #d1d5db;
            font-weight: 500;
        }
        .select-wrapper {
            position: relative;
            width: 100%;
        }
        select {
            width: 100%;
            padding: 14px 40px 14px 16px;
            background-color: #0b0d14;
            border: 1px solid #374151;
            color: #f3f4f6;
            border-radius: 8px;
            font-size: 16px;
            outline: none;
            transition: all 0.2s ease-in-out;
            cursor: pointer;
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.2);
            -webkit-appearance: none;
            -moz-appearance: none;
            appearance: none;
        }
        /* Remove seta padrão no IE (HTA) */
        select::-ms-expand {
            display: none;
        }
        select:focus {
            border-color: #d4af37;
            box-shadow: 0 0 0 2px rgba(212, 175, 55, 0.2);
        }
        .select-wrapper::after {
            content: '▼';
            font-size: 12px;
            color: #d4af37;
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            pointer-events: none;
        }
        
        .btn {
            background: linear-gradient(135deg, #d4af37 0%, #b5952f 100%);
            color: #111827;
            border: none;
            padding: 16px 24px;
            font-size: 17px;
            font-weight: 700;
            border-radius: 8px;
            cursor: pointer;
            width: 100%;
            transition: all 0.2s;
            box-shadow: 0 4px 6px -1px rgba(212, 175, 55, 0.3), 0 2px 4px -1px rgba(212, 175, 55, 0.2);
        }
        .btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 15px -3px rgba(212, 175, 55, 0.4), 0 4px 6px -2px rgba(212, 175, 55, 0.2);
            background: linear-gradient(135deg, #dfbc45 0%, #c2a138 100%);
        }
        .btn:active {
            transform: translateY(1px);
        }
        .btn:disabled {
            background: #444;
            color: #888;
            cursor: not-allowed;
        }

        /* Progress Steps */
        .steps {
            display: none;
            justify-content: space-between;
            margin-bottom: 40px;
            position: relative;
        }
        .steps::before {
            content: '';
            position: absolute;
            top: 25px;
            left: 10%;
            right: 10%;
            height: 2px;
            background-color: #333;
            z-index: 0;
        }
        .step {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 25%;
        }
        .step-icon {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background-color: #1a1d29;
            border: 2px solid #444;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 20px;
            color: #888;
            margin-bottom: 10px;
            transition: all 0.3s;
        }
        .step.active .step-icon {
            border-color: #d4af37;
            color: #d4af37;
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.3);
        }
        .step.done .step-icon {
            background-color: #d4af37;
            border-color: #d4af37;
            color: #000;
        }
        .step-text {
            font-size: 14px;
            color: #888;
        }
        .step.active .step-text {
            color: #fff;
        }
        .step.done .step-text {
            color: #d4af37;
        }

        /* Author Section */
        .author-section {
            background-color: #11141d;
            border-top: 1px solid #2a2d39;
            padding: 20px 30px;
            font-size: 13px;
            color: #888;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: auto;
        }
        .author-info strong {
            color: #d4af37;
            font-size: 14px;
        }
        .author-links {
            display: flex;
            gap: 15px;
        }
        .author-link {
            color: #a0a0a0;
            text-decoration: none;
            transition: color 0.2s;
            cursor: pointer;
        }
        .author-link:hover {
            color: #d4af37;
            text-decoration: underline;
        }

        /* Terms of Use */
        .terms-container {
            margin-bottom: 25px;
            background-color: #0b0d14;
            border: 1px solid #2a2d39;
            border-radius: 8px;
            padding: 15px;
            display: flex;
            align-items: flex-start;
            gap: 10px;
        }
        .terms-container input[type="checkbox"] {
            margin-top: 3px;
            cursor: pointer;
            accent-color: #d4af37;
            width: 16px;
            height: 16px;
        }
        .terms-text {
            font-size: 13px;
            color: #a0a0a0;
            line-height: 1.4;
        }
        .terms-text strong {
            color: #d1d5db;
        }

        /* Status Box */
        .status-box {
            display: none;
            background-color: rgba(46, 125, 50, 0.1);
            border: 1px solid #2e7d32;
            border-radius: 8px;
            padding: 20px;
            align-items: center;
            margin-top: 20px;
        }
        .status-icon {
            background-color: #2e7d32;
            color: white;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 20px;
            margin-right: 15px;
        }
        .status-text h3 {
            margin: 0 0 5px 0;
            color: #4caf50;
            font-size: 18px;
        }
        .status-text p {
            margin: 0;
            font-size: 13px;
            color: #aaa;
        }
        
        .loading {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>

    <div class="header">
        <img src="logoipo.jpg" alt="Logo" style="width: 45px; height: 45px; border-radius: 8px; object-fit: cover; box-shadow: 0 0 10px rgba(212, 175, 55, 0.3);">
        <div class="logo-text">Office-AutoDeployer-<span>Pro</span></div>
    </div>

    <div class="container">
        <div class="card">
            
            <div id="screen-config">
                <h2 class="title">Configuração de Instalação</h2>
                <p class="subtitle">Selecione a versão desejada para instalar e ativar.</p>
                
                <div class="form-group">
                    <label>Versão do Office</label>
                    <div class="select-wrapper">
                        <select id="officeVersion">
                            <option value="1">Microsoft Office 2024 ProPlus (Recomendado)</option>
                            <option value="2">Microsoft Office 365 ProPlus (+ Visio e Project)</option>
                        </select>
                    </div>
                </div>

                <div class="terms-container">
                    <input type="checkbox" id="termsCheckbox" onchange="toggleStartBtn()">
                    <div class="terms-text">
                        <strong>Termos de Uso e Responsabilidade:</strong> Ao prosseguir com a instalação, o usuário declara concordar com os termos de uso deste software, assumindo total responsabilidade por sua utilização em conformidade com as leis de direitos autorais e propriedade intelectual do Brasil e exterior.
                    </div>
                </div>

                <button class="btn" id="btnStart" onclick="startProcess()" disabled>Iniciar Instalação Automática</button>
            </div>

            <div id="screen-progress" style="display: none;">
                <h2 class="title" style="text-align: center; margin-bottom: 40px;">Tudo pronto em poucos cliques!</h2>
                
                <div class="steps" id="steps-container" style="display: flex;">
                    <div class="step active" id="step-1">
                        <div class="step-icon">⬇</div>
                        <div class="step-text">Baixar</div>
                    </div>
                    <div class="step" id="step-2">
                        <div class="step-icon">⚙</div>
                        <div class="step-text">Instalar</div>
                    </div>
                    <div class="step" id="step-3">
                        <div class="step-icon">🔑</div>
                        <div class="step-text">Ativar</div>
                    </div>
                    <div class="step" id="step-4">
                        <div class="step-icon">✔</div>
                        <div class="step-text">Pronto</div>
                    </div>
                </div>

                <div style="text-align: center; margin-top: 30px;">
                    <p id="current-action" style="color: #e0e0e0; font-size: 16px; margin-bottom: 10px;">Preparando...</p>
                    <p id="current-subaction" style="color: #888; font-size: 13px;">Aguarde, não feche esta janela.</p>
                </div>

                <div class="status-box" id="success-box">
                    <div class="status-icon">✔</div>
                    <div class="status-text">
                        <h3>Office instalado e ativado com sucesso!</h3>
                        <p>Aproveite todos os recursos do Microsoft Office.</p>
                    </div>
                </div>

                <button class="btn" id="btnFinish" style="display: none; margin-top: 20px;" onclick="window.close()">Concluir</button>
            </div>

        </div>
    </div>

    <!-- Seção do Autor -->
    <div class="author-section">
        <div class="author-info">
            <strong>Everton Ethan</strong><br>
            Engenheiro de Software / IA / Desenvolvedor Fullstack
        </div>
        <div class="author-links">
            <span class="author-link" onclick="shell.Run('https://www.linkedin.com/in/ethanaiengineer/')">LinkedIn</span>
            <span class="author-link" onclick="shell.Run('https://www.instagram.com/ethan_essencial')">Instagram</span>
            <span class="author-link" style="color: #444;">|</span>
            <span class="author-link" onclick="shell.Run('https://www.devfrontend.com.br')">Site Oficial</span>
            <span class="author-link" onclick="shell.Run('https://www.instagram.com/devfrontendoficial/')">IG DevFrontend</span>
            <span class="author-link" onclick="shell.Run('https://www.facebook.com/devfrontendoficial')">Facebook</span>
        </div>
    </div>

    <script>
        // Resize window to a nice app size (aumentado para evitar corte)
        window.resizeTo(900, 750);
        
        var shell = new ActiveXObject("WScript.Shell");
        var fso = new ActiveXObject("Scripting.FileSystemObject");
        
        // Função para habilitar botão de iniciar
        function toggleStartBtn() {
            var checkbox = document.getElementById("termsCheckbox");
            var btn = document.getElementById("btnStart");
            btn.disabled = !checkbox.checked;
        }
        
        // Obter o diretório atual
        var loc = window.location.pathname;
        if (loc.charAt(0) == '/') loc = loc.substr(1);
        loc = unescape(loc).replace(/\//g, '\\');
        var currentDir = fso.GetParentFolderName(loc);
        shell.CurrentDirectory = currentDir;

        // Verificar Admin
        window.onload = function() {
            var isAdminCode = shell.Run("cmd.exe /c openfiles >nul 2>&1", 0, true);
            if (isAdminCode !== 0) {
                alert("ERRO DE PERMISSÃO!\n\nEste aplicativo precisa ser executado como Administrador.\nPor favor, utilize o atalho 'Instalar_e_Ativar.cmd' ou clique com o botão direito e escolha 'Executar como Administrador'.");
                window.close();
            }

            // Verificar se o Office já está instalado
        try {
            shell.RegRead("HKLM\\SOFTWARE\\Microsoft\\Office\\ClickToRun\\Configuration\\ProductReleaseIds");
            var result = shell.Popup("[AVISO] Foi detectada uma instalacao existente do Microsoft Office neste computador.\n\nE altamente recomendado remover a versao anterior antes de instalar uma nova.\n\nDeseja remover o Office existente agora? (Pode demorar alguns minutos)", 0, "Office AutoDeployer Pro", 4 + 48);
            if (result === 6) { // 6 = Yes/Sim
                removerOfficeAntigo();
            }
        } catch(e) {
            // Não está instalado, segue normal
        }
        };

        function removerOfficeAntigo() {
            try {
                var xmlPath = currentDir + "\\remove-office.xml";
                var xmlContent = '<Configuration><Remove All="TRUE" /><Display Level="None" AcceptEULA="TRUE" /></Configuration>';
                var file = fso.CreateTextFile(xmlPath, true);
                file.Write(xmlContent);
                file.Close();
                
                alert("Iniciando remocao do Office existente. O processo pode demorar alguns minutos. Pressione OK para continuar.");
                shell.Run('cmd.exe /c start /wait setup.exe /configure "' + xmlPath + '"', 0, true);
                
                if (fso.FileExists(xmlPath)) {
                    fso.DeleteFile(xmlPath);
                }
                alert("Remocao concluida com sucesso! Agora voce pode prosseguir com a nova instalacao.");
            } catch(e) {
                alert("Erro ao tentar remover o Office antigo: " + e.message);
            }
        }

        function updateStep(stepNum, status) {
            var step = document.getElementById("step-" + stepNum);
            if (status === 'active') {
                step.className = "step active";
            } else if (status === 'done') {
                step.className = "step done";
                step.innerHTML = '<div class="step-icon">✔</div><div class="step-text" style="margin-top: 10px;">Concluído</div>';
            }
        }

        function setActionText(main, sub) {
            document.getElementById("current-action").innerText = main;
            document.getElementById("current-subaction").innerText = sub;
        }

        function startProcess() {
            var version = document.getElementById("officeVersion").value;
            
            document.getElementById("screen-config").style.display = "none";
            document.getElementById("screen-progress").style.display = "block";

            var xmlFile = (version === "2") ? "configuration-Office365-x64.xml" : "Configuracao.xml";
            var officeName = (version === "2") ? "Office 365 ProPlus" : "Office 2024 ProPlus";

            // Step 1: Remove old versions (Optional, but we can do it silently or skip. Since UI needs to be automated, let's check and remove silently if found, or just proceed to install as setup.exe handles upgrades usually).
            // Actually, original script asks. Let's just run the installation directly to keep it simple and automatic, or we can execute the removal script.
            
            // Let's use setTimeout to allow UI to render
            setTimeout(function() {
                downloadAndInstall(xmlFile, officeName);
            }, 1000);
        }

        function downloadAndInstall(xmlFile, officeName) {
            updateStep(1, 'done');
            updateStep(2, 'active');
            setActionText("Instalando " + officeName + "...", "Uma janela do instalador pode aparecer. Aguarde a conclusão.");

            setTimeout(function() {
                try {
                    // Executa o setup.exe com o XML selecionado e aguarda concluir
                    var cmd = 'cmd.exe /c start /wait setup.exe /configure "' + xmlFile + '"';
                    shell.Run(cmd, 0, true);
                    
                    activateOffice();
                } catch(e) {
                    alert("Erro na instalação: " + e.message);
                }
            }, 500);
        }

        function activateOffice() {
            updateStep(2, 'done');
            updateStep(3, 'active');
            setActionText("Ativando o Office...", "Aplicando ativação permanente (Ohook). Isso pode levar alguns segundos.");

            setTimeout(function() {
                try {
                    // Executa o script de ativação MAS
                    var psCmd = 'powershell -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -Command "& ([ScriptBlock]::Create((New-Object Net.WebClient).DownloadString(\'https://get.activated.win\'))) /Ohook"';
                    shell.Run(psCmd, 0, true);
                    
                    finishProcess();
                } catch(e) {
                    alert("Erro na ativação: " + e.message);
                }
            }, 500);
        }

        function finishProcess() {
            updateStep(3, 'done');
            updateStep(4, 'done');
            
            document.getElementById("current-action").style.display = "none";
            document.getElementById("current-subaction").style.display = "none";
            
            var successBox = document.getElementById("success-box");
            successBox.style.display = "flex";

            document.getElementById("btnFinish").style.display = "block";
        }
    </script>
</body>
</html>